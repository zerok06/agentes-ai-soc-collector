# QRadar API Settings
QRADAR_BASE_URL=https://qradar.company.local/api
QRADAR_API_TOKEN=your_secure_qradar_service_token_here
QRADAR_VERSION=20.0
# Set to true if using a self-signed TLS certificate
QRADAR_TLS_INSECURE=false

# External Ingestion API Settings
DESTINATION_URL=http://localhost:8001/api/v1/ingest/offense
DESTINATION_API_KEY=your_secure_destination_api_key_here

# Collector Behavior
POLL_INTERVAL_SECONDS=60
HTTP_TIMEOUT_SECONDS=30
WORKER_COUNT=5
LOG_LEVEL=info
